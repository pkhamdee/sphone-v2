generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id          String   @id @default(uuid())
  nationalId  String   @unique @map("national_id")
  fullName    String   @map("full_name")
  phoneNumber String   @map("phone_number")
  dateOfBirth DateTime @map("date_of_birth")
  creditLimit Decimal  @default(30000) @map("credit_limit") @db.Decimal(12, 2)
  status      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  orders      Order[]

  @@map("customers")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String
  brand         String
  imageUrl      String   @map("image_url")
  priceAmount   Decimal  @map("price_amount") @db.Decimal(12, 2)
  priceCurrency String   @default("THB") @map("price_currency")
  category      Int
  isAvailable   Boolean  @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")
  orders        Order[]

  @@map("products")
}

model Order {
  id                             String    @id @default(uuid())
  customerId                     String    @map("customer_id")
  productId                      String    @map("product_id")
  productName                    String    @map("product_name")
  installmentProductPrice        Decimal   @map("installment_product_price") @db.Decimal(12, 2)
  installmentDownPayment         Decimal   @map("installment_down_payment") @db.Decimal(12, 2)
  installmentTotalMonths         Int       @map("installment_total_months")
  installmentInterestRate        Decimal   @map("installment_interest_rate") @db.Decimal(6, 4)
  installmentMonthlyAmount       Decimal   @map("installment_monthly_amount") @db.Decimal(12, 2)
  installmentTotalAmount         Decimal   @map("installment_total_amount") @db.Decimal(12, 2)
  status                         Int       @default(0)
  createdAt                      DateTime  @default(now()) @map("created_at")
  approvedAt                     DateTime? @map("approved_at")
  customer                       Customer  @relation(fields: [customerId], references: [id])
  product                        Product   @relation(fields: [productId], references: [id])
  paymentSchedule                PaymentSchedule?

  @@map("orders")
}

model PaymentSchedule {
  id          String        @id @default(uuid())
  orderId     String        @unique @map("order_id")
  totalAmount Decimal       @map("total_amount") @db.Decimal(12, 2)
  totalMonths Int           @map("total_months")
  order       Order         @relation(fields: [orderId], references: [id])
  items       PaymentItem[]

  @@map("payment_schedules")
}

model PaymentItem {
  id                 String          @id @default(uuid())
  paymentScheduleId  String          @map("payment_schedule_id")
  installmentNumber  Int             @map("installment_number")
  dueDate            DateTime        @map("due_date")
  amount             Decimal         @db.Decimal(12, 2)
  status             Int             @default(0)
  paidAt             DateTime?       @map("paid_at")
  paymentSchedule    PaymentSchedule @relation(fields: [paymentScheduleId], references: [id])

  @@map("payment_items")
}
