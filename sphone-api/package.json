{
  "name": "sphone-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5154 --turbopack",
    "build": "next build",
    "start": "next start --port 5154",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node --esm prisma/seed.ts",
