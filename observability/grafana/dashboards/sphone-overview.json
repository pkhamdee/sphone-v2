      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(sphone_v8js_memory_heap_used_bytes{exported_job=~\"sphone/.*\"}) by (exported_job) / 1024 / 1024",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "title": "Node.js \u2014 Heap Memory (MB)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
