      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(sphone_customers_registered_total[24h]))",
          "legendFormat": "Customers (24h)"
        }
      ],
      "title": "Customers Registered",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 6,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(sphone_order_installment_amount_thb_bucket[5m])) by (le)",
          "legendFormat": "{{le}} THB"
        }
      ],
      "title": "Monthly Installment Distribution (THB)",
      "type": "histogram"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
