{
  "title": "sPhone — Service Overview",
  "uid": "sphone-overview",
  "tags": ["sphone"],
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=~\"sphone.*\"}[1m])) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{service_name=~\"sphone.*\"}[1m])) by (le, service_name))",
          "legendFormat": "{{service_name}} p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\",service_name=~\"sphone.*\"}[1m])) by (service_name) / sum(rate(http_server_duration_milliseconds_count{service_name=~\"sphone.*\"}[1m])) by (service_name)",
          "legendFormat": "{{service_name}} errors %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Orders Created",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(sphone_sphone_orders_created_total[24h]))",
          "legendFormat": "Orders (24h)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Customers Registered",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(sphone_sphone_customers_registered_total[24h]))",
          "legendFormat": "Customers (24h)"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "Monthly Installment Distribution (THB)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(sphone_sphone_order_installment_amount_thb_bucket[5m])) by (le)",
          "legendFormat": "{{le}} THB"
        }
      ]
    },
    {
      "id": 7,
      "title": ".NET Runtime — GC Heap (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_runtime_dotnet_gc_heap_size_bytes{service_name=\"sphone-api\"} / 1024 / 1024",
          "legendFormat": "Heap (gen {{generation}})"
        }
      ]
    },
    {
      "id": 8,
      "title": ".NET Thread Pool Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_runtime_dotnet_thread_pool_queue_length{service_name=\"sphone-api\"}",
          "legendFormat": "Queue length"
        }
      ]
    },
    {
      "id": 10,
      "title": "Traces",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "id": 11,
      "title": "Recent Traces — sphone services",
      "type": "traces",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"sphone.*\"}",
          "limit": 20,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 12,
      "title": "Error Traces",
      "type": "traces",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 37 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"sphone.*\" && status=error}",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Slow Traces (>500ms)",
      "type": "traces",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 37 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"sphone.*\" && duration>500ms}",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Logs (sphone-api)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 49 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"sphone-api\"} | json",
          "legendFormat": ""
        }
      ]
    }
  ]
}
