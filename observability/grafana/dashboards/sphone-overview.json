{
  "id": 1,
  "panels": [
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(sphone_http_server_duration_milliseconds_count{exported_job=~\"sphone/.*\"}[1m])) by (exported_job)",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(sphone_http_server_duration_milliseconds_bucket{exported_job=~\"sphone/.*\"}[1m])) by (le, exported_job))",
          "legendFormat": "{{exported_job}} p99"
        }
      ],
      "title": "P99 Latency (ms)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(rate(sphone_http_server_duration_milliseconds_count{http_status_code=~\"[45]..\",exported_job=~\"sphone/.*\"}[1m])) by (exported_job) / sum(rate(sphone_http_server_duration_milliseconds_count{exported_job=~\"sphone/.*\"}[1m])) by (exported_job)",
          "legendFormat": "{{exported_job}} errors %"
        }
      ],
      "title": "Error Rate (%)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(sphone_orders_created_total[24h]))",
          "legendFormat": "Orders (24h)"
        }
      ],
      "title": "Orders Created",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
