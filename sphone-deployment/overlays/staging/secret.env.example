# Copy to secret.env and fill in staging values
# secret.env is git-ignored

# sphone-api
ConnectionStrings__Database=Host=sphone-postgres;Port=5432;Database=sphone;Username=sphone;Password=changeme-staging
ConnectionStrings__Redis=sphone-redis:6379
Jwt__Secret=staging-secret-key-minimum-32-characters-here!

# sphone-postgres
POSTGRES_USER=sphone
POSTGRES_PASSWORD=changeme-staging
