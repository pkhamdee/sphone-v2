# Copy to secret.env and fill in PRODUCTION values
# secret.env is git-ignored — use a secrets manager (Vault, AWS Secrets Manager, etc.)

# sphone-api
ConnectionStrings__Database=Host=<RDS-ENDPOINT>;Port=5432;Database=sphone;Username=sphone;Password=<STRONG-PASSWORD>;SSL Mode=Require
ConnectionStrings__Redis=<ELASTICACHE-ENDPOINT>:6379
Jwt__Secret=<STRONG-SECRET-MINIMUM-64-CHARACTERS-USE-OPENSSL-RAND-BASE64-64>

# sphone-postgres (only used if running postgres in-cluster, else use managed RDS)
POSTGRES_USER=sphone
POSTGRES_PASSWORD=<STRONG-PASSWORD>
